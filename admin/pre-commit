#!/bin/sh

STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACMR HEAD | grep '\.php$')

if [ -z "$STAGED_PHP_FILES" ]; then
    exit 0
fi

echo "Linting PHP syntax..."
for FILE in $STAGED_PHP_FILES; do
    php -l -d display_errors=0 "$FILE"
    if [ $? != 0 ]; then
        echo "Fix the syntax error(s) before committing."
        exit 1
    fi
done

echo "Auto-fixing code style on staged files..."
# shellcheck disable=SC2086
php ./vendor/bin/php-cs-fixer fix --quiet $STAGED_PHP_FILES

# Re-stage files so auto-fixes are included in the commit
# shellcheck disable=SC2086
git add $STAGED_PHP_FILES
